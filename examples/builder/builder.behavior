// builder.behavior
// Full lifecycle for the Builder agent.
// Covers onboarding, new agent/skill creation, evolution, self-evolution, review, and upgrade.
// The planning phase is inlined to illustrate multi-state orchestration;
// generation phase is extracted via merge (too dense for .behavior — belongs in .run).

merge "phases/generation.behavior"
merge "phases/planning.behavior"

on event "action_failed"
  set worksession.backlog_count += 1
  run script "scripts/log_error.sh"

// ─── Init & Onboarding ────────────────────────────────────────────────────────

state init
  if session.is_first_time
    transition to onboarding
  else
    transition to responsive

state onboarding
  run script "scripts/detect-env.sh"
  guide "phases/onboarding.md"
  goal "Collect user profile and understand their working environment."
  interact
  on intent "profile_complete"
    set user.has_profile = true
    set session.is_first_time = false
    transition to responsive
  on offtopic
    transition to responsive

// ─── Main Router ──────────────────────────────────────────────────────────────

state responsive
  guide "AGENTS.md"
  interact
  on intent "new" transition to planning.context
  on intent "skill" transition to planning.context
  on intent "evolve" transition to evolve
  on intent "self" transition to self_evolve
  on intent "review" transition to review
  on intent "upgrade" transition to upgrade
  on offtopic
    transition to responsive

// ─── Planning Phase ───────────────────────────────────────────────────────────

state planning.context
  set worksession.active_phase = "1. Planning"
  set session.has_claude = run tool "Fs.Exists" "CLAUDE.md"
  if session.has_claude
    set context.claude_rules = run tool "Fs.ReadFile" "CLAUDE.md"
  set context.spec = run tool "Fs.ReadFile" "phases/shared/_skill-spec.md"
  transition to planning.initial_checks

state planning.initial_checks
  parallel
    run subagent "meta_checks"
    run subagent "automation_radar"
  on complete
    set context.radar_results = run tool "Memory.Get" "radar_results"
    guide "planning-guide.md#phase_1"
    goal "Present consolidated results and await user approval."
    interact
    on intent "user_approved" transition to planning.concept
    on intent "user_rejected" transition to planning.cancel
    on offtopic
      transition to planning.cancel
  on failed
    run tool "Log.Error" "Initial checks failed"
    transition to planning.cancel

state planning.concept
  guide "planning-guide.md#golden_rule"
  goal "Iteratively extract Idea, Name, Description, and Operational Modes."
  interact
  on intent "concept_ready"
    set worksession.concept_defined = true
    transition to planning.structure
  on offtopic
    transition to planning.cancel

state planning.structure
  guide "planning-guide.md#structure"
  goal "Define if this will be a single SKILL.md, modular, or a full Agent."
  interact
  on intent "structure_ready" transition to planning.references
  on offtopic
    transition to planning.cancel

state planning.references
  teach "websearch.knowledge"
  goal "Search for similar references on the web and present up to 3 examples."
  interact
  on intent "references_ready" transition to planning.handoff
  on offtopic
    transition to planning.cancel

state planning.handoff
  goal "Present structured planning summary and request final confirmation."
  interact
  on intent "handoff_approved"
    set worksession.handoff_ready = true
    transition to planning.quality_check
  on offtopic
    transition to planning.cancel

state planning.quality_check
  run subagent "planning_quality_checker"
  on complete
    if context.quality_passed == true
      transition to phases.generation.scaffold
    else
      transition to planning.cancel
  on failed
    transition to planning.cancel

state planning.cancel
  run tool "Log.Info" "Planning cancelled or failed quality check."
  transition to responsive

// ─── Review Phase ─────────────────────────────────────────────────────────────

state review
  set worksession.active_phase = "Review"
  guide "phases/review.md"
  goal "Audit the target agent or skill against current spec and best practices."
  interact
  on intent "target_ready"
    set context.review_target = run tool "Fs.ReadDir" context.target_path
    transition to review.analyze
  on offtopic
    transition to responsive

state review.analyze
  parallel
    run subagent "spec_compliance_checker"
    run subagent "security_auditor"
  on complete
    set context.review_results = run tool "Memory.Get" "review_results"
    guide "phases/review.md#report"
    goal "Present findings and propose improvements."
    interact
    on intent "review_complete" transition to responsive
    on intent "evolve_now" transition to evolve
    on offtopic
      transition to responsive
  on failed
    guide "Review could not be completed. Check agent path and try again."
    transition to responsive

// ─── Evolution (AgentEvolution) ───────────────────────────────────────────────

state evolve
  set worksession.active_phase = "Evolution"
  guide "phases/evolve.md"
  goal "Identify which agent or skill will be evolved and what changes are needed."
  interact
  on intent "target_identified"
    set worksession.evolve_target = context.target
    transition to evolve.confirm
  on offtopic
    transition to responsive

state evolve.confirm
  goal "Confirm authorization to modify the target agent package."
  interact
  on intent "evolution_confirmed"
    transition to planning.context
  on offtopic
    transition to responsive

// ─── Self-Evolution (SelfEvolution) ───────────────────────────────────────────

state self_evolve
  goal "Propose improvements to the Builder agent's own behavior files."
  interact
  on intent "self_evolution_approved"
    set worksession.evolve_target = "builder"
    transition to evolve.confirm
  on offtopic
    transition to responsive

// ─── Upgrade (AgentUpgrade) ───────────────────────────────────────────────────

state upgrade
  goal "Apply a Runtime-approved version update to an agent package."
  interact
  on intent "upgrade_confirmed"
    run script "scripts/apply-upgrade.sh"
    on complete
      guide "Upgrade applied successfully."
      transition to responsive
    on failed
      guide "Upgrade failed. The previous version remains active."
      transition to responsive
  on offtopic
    transition to responsive
