agent Mickey Mouse
  domain disney.com
  license Copyright
  terms https://disney.com/terms
  privacy https://disney.com/privacy

// pq aqui o texto tá sem "" e no capability tem? 
description
  This agent generates images of Mickey Mouse based on a given text prompt and an optional image input. It can produce both a standard image of Mickey Mouse and an avatar with Mickey Mouse ears, along with metadata about the generation process.

// === NOTA ARQUITETURAL: METADADOS & LICENÇA ===
// No passado, este arquivo tentava listar `license http://www.disney.com/copyright`
// e `author Disney`. Sob a nova arquitetura (3-Layer Packaging), metadados engessados
// ficam na Layer 2 (Envelope).
// Na Layer 1 (aqui), a keyword `domain disney.com` garante criptograficamente a 
// Propriedade Intelectual. A Runtime invalidará este agente se o criador não
// provar ser dono de disney.com, impedindo pirataria do Mickey.
// ==============================================

behavior mickey.flow

// === NOTA ARQUITETURAL: ENDPOINTS (MCP / UI) ===
// Anteriormente, questionamos como declarar endpoints remotos (ex: https://api.disney.ai/mickey).
// Endpoints são infraestrutura (Layer 2). O manifesto (.agent) não lista URLs físicas.
// Ao declarar o `domain disney.com`, o empacotador gerará a `urn:agent:com.disney:mickeymouse`.
// A Runtime usará essa URN para baixar os endereços reais do Registry oficial.
// ===============================================

input std.Prompt, std.ImageObject

capabilities
  // === NOTA ARQUITETURAL: NAMESPACES & CAPABILITIES ===
  // O uso das Capabilities atua como o Header File (.h) e Contrato de Segurança.
  // Ações de criação de IP protegido rodam sob a restrição do domínio disney.com.
  // ====================================================
  // como ter esse lock? Agentes de IP rodariam localmente? que travas é possivel entrar na spec?
  CreateAction "Generate images of Mickey Mouse based on text prompts"
  CreateAction "Create avatars with Mickey Mouse ears"
  custom.SpeechSynthesis "Transform text into speech with Mickey Mouse's voice"

output
  AvatarWithMickey
  AvatarWithEars
  Speech

// Tipos Customizados Locais
type AvatarWithMickey
  concept https://schema.org/ImageObject
  image: Avatar

type AvatarWithEars
  concept https://schema.org/ImageObject
  image: Avatar

type Speech
  concept https://schema.org/AudioObject
