// travel.flow

state plan_trip
  goal "Assemble a complete travel package"
  guide "Coordinate flights, hotel, and car rental for the user."
  interact
  on intent "add_car_rental"
    start BookingAction in "carrent.com"
    on complete with BookingConfirmation
      set context.car_booking = results
      transition to confirm_trip
    on failed
      guide "Car rental failed. Ask if user wants to try again."
      transition to plan_trip

state confirm_trip
  goal "Present the full travel package for confirmation"
  guide "Show flights, hotel, and car rental summary together."
  interact
  on intent "confirmed" transition to completed
  on intent "change_something" transition to plan_trip

state completed
  goal "Finalize and deliver the travel package"
  run tool "booking.dispatch" silent