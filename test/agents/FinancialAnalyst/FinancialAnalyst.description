agent FinancialAnalyst
    domain compliance.dot-agent.org
    license Apache-2.0
    terms https://compliance.dot-agent.org/terms

description
Processes fiscal and operational expenditures directly within client memory.
Provides deterministic validation before auditing pipelines.

input
    ExpenseLedger "O livro-caixa digital contendo os lançamentos brutos"

output
    AuditReport "Relatório estruturado com inconformidades fiscais"

type ExpenseLedger
category https://wikidata.org/wiki/Q3874057
concept https://schema.org/FinancialProduct
ledger_id: string(template "LED-9999-AA")
total_amount: number "Valor total consolidado"
is_audited: boolean

type AuditReport
category https://wikidata.org/wiki/Q1087053
report_hash: string(format hash)
discrepancies_found: number