{
  "name": "tree-sitter-agent",
  "version": "0.1.0",
  "description": "Tree-sitter grammars for the Agent DSL (.agent / .type / .flow)",
  "scripts": {
    "generate":      "tree-sitter generate",
    "generate-flow": "cd flow && npx tree-sitter generate",
    "test":          "tree-sitter test",
    "test-flow":     "cd flow && npx tree-sitter test",
    "parse":         "tree-sitter parse"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.0"
  },
  "tree-sitter": [
    {
      "scope": "source.agent",
      "file-types": ["agent", "type"]
    },
    {
      "scope": "source.flow",
      "file-types": ["flow"]
    }
  ]
}
