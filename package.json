{
  "name": "@dot-agent/tree-sitter-agent",
  "version": "0.2.0",
  "description": "Tree-sitter grammars for the Agent DSL (.description / .type / .behavior)",
  "main": "index.js",
  "files": [
    "index.js",
    "dist/",
    "queries/",
    "grammar.js",
    "tree-sitter.json",
    "src/node-types.json",
    "behavior/grammar.js",
    "behavior/queries/",
    "behavior/src/node-types.json"
  ],
  "license": "Apache-2.0",
  "author": "Danilo Borges <contato@daniloborg.es>",
  "repository": {
    "type": "git",
    "url": "https://github.com/daniloborges/tree-sitter-agent.git"
  },
  "homepage": "https://github.com/daniloborges/tree-sitter-agent#readme",
  "bugs": {
    "url": "https://github.com/daniloborges/tree-sitter-agent/issues"
  },
  "keywords": ["tree-sitter", "agent", "dsl", "parser", "grammar"],
  "scripts": {
    "generate":           "tree-sitter generate",
    "generate-behavior":  "cd behavior && npx tree-sitter generate",
    "test":               "tree-sitter test",
    "test-behavior":      "cd behavior && npx tree-sitter test",
    "parse":              "tree-sitter parse",
    "clean":              "node scripts/clean.js",
    "prebuild":           "npm run clean",
    "build:wasm-agent":    "tree-sitter build --wasm && mv tree-sitter-agent.wasm dist/",
    "build:wasm-behavior": "cd behavior && tree-sitter build --wasm && mv tree-sitter-behavior.wasm ../dist/",
    "build":              "npm run build:wasm-agent && npm run build:wasm-behavior",
    "prepublishOnly":     "npm run build"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.0"
  },
  "tree-sitter": [
    {
      "scope": "source.description",
      "file-types": ["description", "type"]
    },
    {
      "scope": "source.behavior",
      "file-types": ["behavior"]
    }
  ],
  "publishConfig": {
    "access": "public"
  }
}
