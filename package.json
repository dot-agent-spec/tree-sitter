{
  "name": "@dot-agent/tree-sitter-agent",
  "version": "0.1.0",
  "description": "Tree-sitter grammars for the Agent DSL (.agent / .type / .flow)",
  "main": "index.js",
  "files": [
    "index.js",
    "dist/",
    "queries/",
    "grammar.js",
    "tree-sitter.json",
    "src/node-types.json",
    "flow/grammar.js",
    "flow/queries/",
    "flow/src/node-types.json"
  ],
  "license": "Apache-2.0",
  "author": "Danilo Borges <contato@daniloborg.es>",
  "repository": {
    "type": "git",
    "url": "https://github.com/daniloborges/tree-sitter-agent.git"
  },
  "homepage": "https://github.com/daniloborges/tree-sitter-agent#readme",
  "bugs": {
    "url": "https://github.com/daniloborges/tree-sitter-agent/issues"
  },
  "keywords": ["tree-sitter", "agent", "dsl", "parser", "grammar"],
  "scripts": {
    "generate":      "tree-sitter generate",
    "generate-flow": "cd flow && npx tree-sitter generate",
    "test":          "tree-sitter test",
    "test-flow":     "cd flow && npx tree-sitter test",
    "parse":         "tree-sitter parse",
    "clean": "node scripts/clean.js",
    "prebuild": "npm run clean",
    "build:wasm-agent": "tree-sitter build --wasm && mv tree-sitter-agent.wasm dist/",
    "build:wasm-flow": "cd flow && tree-sitter build --wasm && mv tree-sitter-flow.wasm ../dist/",
    "build": "npm run build:wasm-agent && npm run build:wasm-flow",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.0"
  },
  "tree-sitter": [
    {
      "scope": "source.agent",
      "file-types": ["agent", "type"]
    },
    {
      "scope": "source.flow",
      "file-types": ["flow"]
    }
  ],
  "publishConfig": {
    "access": "public"
  }
}
